# ─────────────────────────────────────────────────────────────────────────
# apps/web (Next.js) — copia a .env.local y rellena. NUNCA commitear .env.local.
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase (cliente) ──
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Llave PUBLISHABLE (anon) — pública por diseño (RLS protege los datos).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Stripe (cliente) ──
# Publishable key (pk_test_… en pruebas). Pública; la usan el checkout y guardar tarjeta.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Backend (apps/api) — SOLO servidor (Server Actions), NUNCA en el navegador ──
# URL base del backend Express. En dev normalmente http://localhost:4000.
# El frontend la usa para /buyers, /payments, /sellers, etc.
API_INTERNAL_URL=http://localhost:4000
# Secreto compartido con apps/api (CLAIM_SERVICE_TOKEN IDÉNTICO allá) para autorizar
# /buyers/register y /sellers/claim.
CLAIM_SERVICE_TOKEN=
# (Compat) Si NO defines API_INTERNAL_URL, la base del backend se deriva de esta URL
# quitándole el sufijo /sellers/claim:
# CLAIM_SERVICE_URL=http://localhost:4000/sellers/claim
